generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id              String             @id @default(cuid())
  participantCode String?            @map("participant_code")
  condition       String?
  startedAt       DateTime           @default(now()) @map("started_at")
  endedAt         DateTime?          @map("ended_at")
  finalMinutes    FinalMinute[]
  subSlotStates    SlotSubState[]
  slotStates      SlotState[]
  utterances      SessionUtterance[]
  microphonePairingTokens MicrophonePairingToken[]
  webRtcSignals   WebRtcSignal[]

  @@index([startedAt])
  @@index([participantCode])
  @@map("sessions")
}

model MicrophonePairingToken {
  id         String    @id @default(cuid())
  sessionId  String    @map("session_id")
  role       String
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, role])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("microphone_pairing_tokens")
}

model WebRtcSignal {
  id          String   @id
  sessionId   String   @map("session_id")
  role        String
  sender      String
  recipient   String
  messageType String   @map("message_type")
  payload     Json
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime @map("expires_at")
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, role, recipient, createdAt])
  @@index([expiresAt])
  @@map("web_rtc_signals")
}

model SessionUtterance {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  speaker   String
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([speaker])
  @@index([createdAt])
  @@map("utterances")
}

model SlotState {
  id                String   @id @default(cuid())
  sessionId         String   @map("session_id")
  slotName          String   @map("slot_name")
  status            String
  summary           String
  evidenceUtterance String?  @map("evidence_utterance")
  updatedAt         DateTime @updatedAt @map("updated_at")
  session           Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, slotName])
  @@index([sessionId])
  @@index([status])
  @@map("slot_states")
}

model SlotSubState {
  id                   String   @id @default(cuid())
  sessionId            String   @map("session_id")
  mainSlotId           String   @map("main_slot_id")
  subSlotId            String   @map("sub_slot_id")
  completion           String
  responseState        String   @map("response_state")
  reasonCode           String?  @map("reason_code")
  evidenceUtteranceIds Json     @map("evidence_utterance_ids")
  canAskAgain          Boolean  @default(true) @map("can_ask_again")
  isDeferred           Boolean  @default(false) @map("is_deferred")
  lastUpdatedTopicId   String?  @map("last_updated_topic_id")
  updatedAt            DateTime @updatedAt @map("updated_at")
  session              Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, mainSlotId, subSlotId])
  @@index([sessionId])
  @@index([mainSlotId])
  @@index([subSlotId])
  @@index([completion])
  @@index([responseState])
  @@index([reasonCode])
  @@map("slot_sub_states")
}

model FinalMinute {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  markdown  String
  json      Json
  createdAt DateTime @default(now()) @map("created_at")
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("final_minutes")
}
