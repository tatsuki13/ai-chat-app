generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ExperimentSession {
  id                              String     @id
  condition                       String?
  startedAt                       DateTime?
  completedAt                     DateTime?
  presetTopicDurationMs           Int?
  silenceSoftThresholdMs          Int?
  silenceInterventionThresholdMs  Int?
  maxSilenceInterventionsPerTopic Int?
  rawLog                          Json?
  createdAt                       DateTime   @default(now())
  updatedAt                       DateTime   @updatedAt
  topicLogs                       TopicLog[]

  @@index([condition])
  @@index([startedAt])
}

model TopicLog {
  id                        String            @id @default(cuid())
  sessionId                 String
  topicId                   String
  topicIndex                Int
  level                     Int?
  lead                      String?
  question                  String
  acpSlots                  String[]          @default([])
  expressedPoints           Json?
  missingOrUnclearSlots     String[]          @default([])
  slotEvidence              Json?
  presentedAt               DateTime?
  startedAt                 DateTime?
  endedAt                   DateTime?
  firstUtteranceAt          DateTime?
  latencyToFirstUtteranceMs Int?
  endReason                 String?
  interventionCount         Int               @default(0)
  silenceInterventionCount  Int               @default(0)
  utteranceCountUser        Int               @default(0)
  utteranceCountPartner     Int               @default(0)
  totalUserCharCount        Int               @default(0)
  totalPartnerCharCount     Int               @default(0)
  firstUtteranceDetected    Boolean           @default(false)
  lastHumanUtteranceEndAt   DateTime?
  currentState              String?
  stateHistory              Json?
  silenceEvents             Json?
  rawLog                    Json?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  interventions             Intervention[]
  session                   ExperimentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  utterances                Utterance[]

  @@unique([sessionId, topicIndex])
  @@index([sessionId])
  @@index([topicId])
}

model Utterance {
  id         String   @id @default(cuid())
  topicLogId String
  speaker    String
  text       String
  eventType  String
  timestamp  DateTime
  messageId  Int?
  charCount  Int?
  rawEntry   Json?
  createdAt  DateTime @default(now())
  topicLog   TopicLog @relation(fields: [topicLogId], references: [id], onDelete: Cascade)

  @@index([topicLogId])
  @@index([speaker])
  @@index([timestamp])
}

model Intervention {
  id                 String   @id @default(cuid())
  topicLogId         String
  reason             String
  interventionNumber Int?
  promptedSlot       String?
  aiReflectionText   String
  silenceDurationMs  Int?
  expressedPoints    Json?
  source             String?
  messageId          Int?
  timestamp          DateTime
  rawEntry           Json?
  createdAt          DateTime @default(now())
  topicLog           TopicLog @relation(fields: [topicLogId], references: [id], onDelete: Cascade)

  @@index([topicLogId])
  @@index([reason])
  @@index([timestamp])
}

model Session {
  id              String             @id @default(cuid())
  participantCode String?            @map("participant_code")
  condition       String?
  startedAt       DateTime           @default(now()) @map("started_at")
  endedAt         DateTime?          @map("ended_at")
  aiSuggestions   AiSuggestionLog[]
  buttonEvents    ButtonEvent[]
  finalMinutes    FinalMinute[]
  slotStates      SlotState[]
  utterances      SessionUtterance[]

  @@index([participantCode])
  @@index([startedAt])
  @@map("sessions")
}

model SessionUtterance {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  speaker   String
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([speaker])
  @@index([createdAt])
  @@map("utterances")
}

model ButtonEvent {
  id            String            @id @default(cuid())
  sessionId     String            @map("session_id")
  buttonType    String            @map("button_type")
  createdAt     DateTime          @default(now()) @map("created_at")
  aiSuggestions AiSuggestionLog[] @relation("TriggerButtonEvent")
  session       Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([buttonType])
  @@index([createdAt])
  @@map("button_events")
}

model AiSuggestionLog {
  id             String       @id @default(cuid())
  sessionId      String       @map("session_id")
  triggerEventId String?      @map("trigger_event_id")
  suggestionType String       @map("suggestion_type")
  content        String
  reasoning      String?
  targetSlot     String?      @map("target_slot")
  adopted        Boolean?
  createdAt      DateTime     @default(now()) @map("created_at")
  session        Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  triggerEvent   ButtonEvent? @relation("TriggerButtonEvent", fields: [triggerEventId], references: [id])

  @@index([sessionId])
  @@index([triggerEventId])
  @@index([suggestionType])
  @@index([createdAt])
  @@map("ai_suggestions")
}

model SlotState {
  id                String   @id @default(cuid())
  sessionId         String   @map("session_id")
  slotName          String   @map("slot_name")
  status            String
  summary           String
  evidenceUtterance String?  @map("evidence_utterance")
  updatedAt         DateTime @updatedAt @map("updated_at")
  session           Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, slotName])
  @@index([sessionId])
  @@index([status])
  @@map("slot_states")
}

model FinalMinute {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  markdown  String
  json      Json
  createdAt DateTime @default(now()) @map("created_at")
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("final_minutes")
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}
